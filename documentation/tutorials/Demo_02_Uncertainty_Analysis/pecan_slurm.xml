 <host>
   <prerun>module load openmpi5/5.0.6 ; export OMP_NUM_THREADS=1</prerun>
   <qsub>sbatch -v -J @NAME@ -o @STDOUT@ -e @STDERR@ --cpus-per-task=1</qsub>
   <qsub.jobid>Submitted batch job ([[:digit:]]+)</qsub.jobid>
   <qstat>squeue -h --job @JOBID@ || echo "DONE"</qstat>
